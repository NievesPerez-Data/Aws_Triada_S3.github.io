---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Nieves Pérez",
    description:
      "Business Intelligence & Strategy. Especialista en transformar KPIs de negocio y retail en decisiones comerciales accionables.",
    icon: "bx:bxs-briefcase",
  },
  {
    title: "Mayka Durán",
    description:
      "Data Analyst & Operations. Experta en optimización de procesos operativos mediante el uso de Python, SQL y modelado de datos.",
    icon: "bx:bxs-analyse",
  },
  {
    title: "Laura Parejo",
    description:
      "Senior Product Designer. Estrategia de producto y diseño UX/UI escalable para convertir problemas complejos en soluciones usables.",
    icon: "bx:bxs-paint-roll",
  },
  {
    title: "Análisis de Datos",
    description:
      "Exploración, limpieza y transformación de datasets. Convertimos datos crudos en dashboards visuales (Tableau/Power BI).",
    icon: "bx:bxs-data",
  },
  {
    title: "Soluciones AWS Cloud",
    description:
      "Infraestructura escalable y segura. Aplicamos el estándar AWS re/Start para garantizar un rendimiento óptimo en la nube.",
    icon: "bx:bxl-aws",
  },
  {
    title: "Estrategia Digital",
    description:
      "Alineamos tecnología, diseño y objetivos de negocio para asegurar que cada producto digital genere un impacto real.",
    icon: "bx:bxs-rocket",
  },
];
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Expertise 360°: De los datos a la estrategia
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    Unimos el análisis de datos avanzado, la optimización de procesos operativos y el diseño de producto bajo un mismo nexo: la potencia de AWS.
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item) => (
      <div class="flex gap-4 items-start">
        <div class="mt-1 bg-black rounded-full p-2 w-8 h-8 shrink-0">
          <Icon class="text-white" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>{" "}
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>