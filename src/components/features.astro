---
// @ts-ignore
import { Icon } from "astro-icon/components";

const services = [
  {
    title: "Análisis Estratégico",
    description:
      "Transformamos KPIs complejos en decisiones comerciales. Especialistas en unir la operativa de negocio con analítica de alta precisión.",
    icon: "bx:bxs-pie-chart-alt-2",
  },
  {
    title: "Optimización de Procesos",
    description:
      "Eliminamos cuellos de botella operativos mediante Python y SQL, garantizando que cada flujo de trabajo sea eficiente y medible.",
    icon: "bx:bxs-component",
  },
  {
    title: "Diseño de Producto UX",
    description:
      "Diseñamos experiencias digitales escalables basadas en datos de usuario, asegurando productos intuitivos y de alto impacto.",
    icon: "bx:bxs-paint-roll",
  },
  {
    title: "Arquitectura Cloud AWS",
    description:
      "Implementamos soluciones nativas en la nube bajo estándares de AWS re/Start, aportando seguridad y escalabilidad total.",
    icon: "bx:bxl-aws",
  },
  {
    title: "Business Intelligence",
    description:
      "Creación de dashboards avanzados en Tableau y Power BI que permiten visualizar el estado real de tu negocio en tiempo real.",
    icon: "bx:bxs-data",
  },
  {
    title: "Estrategia de Conversión",
    description:
      "Auditamos y rediseñamos embudos de venta para maximizar el ROI, uniendo métricas de comportamiento con visión de negocio.",
    icon: "bx:bxs-rocket",
  },
];
---

<div class="max-w-6xl mx-auto px-4">
  <div class="mt-16 text-center">
    <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
      Experiencia 360°: De los datos a la estrategia
    </h2>
    <p class="text-lg mt-4 text-slate-600 max-w-2xl mx-auto">
      Unimos analítica avanzada, optimización operativa y diseño de producto bajo la potencia de AWS.
    </p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 mt-16 gap-8">
    {
      services.map((item) => (
        <div class="flex flex-col items-center text-center p-8 rounded-2xl border border-slate-200 bg-white hover:border-orange-400 hover:shadow-xl transition-all duration-300 group">
          <div class="bg-orange-50 rounded-xl p-3 w-14 h-14 flex items-center justify-center group-hover:bg-orange-500 transition-colors duration-300">
            <Icon class="text-orange-500 w-8 h-8 group-hover:text-white" name={item.icon} />
          </div>
          <h3 class="font-bold text-xl mt-6">{item.title}</h3>
          <p class="text-slate-500 mt-3 leading-relaxed text-sm">
            {item.description}
          </p>
        </div>
      ))
    }
  </div>
</div>