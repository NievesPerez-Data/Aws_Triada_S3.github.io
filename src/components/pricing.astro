---
import Link from "./link.astro";

const { plan } = Astro.props;
---

<div class={`flex flex-col w-full border-2 py-8 px-6 rounded-2xl transition-all ${plan.popular ? 'border-indigo-500 shadow-xl scale-105 z-10' : 'border-slate-200 bg-white'}`}>
  
  {plan.popular && (
    <span class="bg-indigo-600 text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full w-max mx-auto mb-4">
      Recomendado
    </span>
  )}

  <div class="text-center">
    <h4 class="text-lg font-medium text-slate-500 uppercase tracking-wider">
      {plan.name}
    </h4>
    <p class="mt-3 text-4xl font-bold text-slate-900">
      {plan.price}
    </p>
  </div>

  <ul class="grid mt-8 text-left gap-y-4 flex-1">
    {
      plan.features?.map((item) => (
        <li class="flex items-start gap-3 text-slate-600 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>{item}</span>
        </li>
      ))
    }
  </ul>

  <div class="flex mt-10">
    <Link
      href={plan.button?.link || "/contact"}
      block
      style={plan.popular ? "primary" : "outline"}
    >
      {plan.button?.text || "Saber más"}
    </Link>
  </div>
</div>