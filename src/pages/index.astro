---
import Container from "@/components/container.astro";
import Cta from "@/components/cta.astro";
import Features from "@/components/features.astro";
import Hero from "@/components/hero.astro";
import Logos from "@/components/logos.astro";
import Layout from "@/layouts/Layout.astro";
import Sectionhead from "@/components/sectionhead.astro";
import Team from "@/components/team.astro";

const team = [
  {
    name: "Nieves Pérez",
    role: "Strategy & Business Intelligence Lead",
    desc: "Especialista en unir la operativa de negocio con analítica avanzada. Experta en KPIs de Retail y toma de decisiones estratégicas basadas en evidencias.",
    linkedin: "https://www.linkedin.com/in/nievesperezalonso",
  },
  {
    name: "Mayka Durán",
    role: "Operations & Data Analyst Lead",
    desc: "Arquitecta de eficiencia operativa. Utiliza Python y SQL para limpiar y automatizar flujos de datos, eliminando fricciones en el escalado de negocios.",
    linkedin: "https://www.linkedin.com/in/mdelcarmenduran/",
  },
  {
    name: "Laura Parejo",
    role: "Senior Product & UX Lead",
    desc: "Más de 10 años diseñando productos digitales globales. Transforma la complejidad técnica en interfaces intuitivas que maximizan la conversión.",
    linkedin: "https://www.linkedin.com/in/laura-parejo-aranda",
  },
  {
    name: "Esther Quirós",
    role: "FullStack Developer",
    desc: "Desarrollador FullStack que transforma ideas en aplicaciones web eficientes con React, Node.js y MySQL, aplicando metodologías ágiles.",
    linkedin: "https://www.linkedin.com/in/esther-quir%C3%B3s/",
  },
];
---

<style>
  /* Definimos vuestra gama: Melocotón -> Coral -> Lavanda */
  .triad-gradient-text {
    background: linear-gradient(
      135deg,
      #ffdab9 0%,
      /* Melocotón */ #f4a460 30%,
      /* Arena */ #f08080 60%,
      /* Coral */ #e6e6fa 100% /* Lavanda */
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }
</style>

<Layout title="TRIAD | Data, Strategy & Product">
  <Container>
    <Hero />

    <Logos />

    <section id="servicios" class="scroll-mt-24 py-16">
      <Sectionhead>
        <Fragment slot="title">Nuestros Servicios</Fragment>
        <Fragment slot="desc">
          Soluciones integrales que unen la analítica avanzada con el diseño de
          producto escalable.
        </Fragment>
      </Sectionhead>
      <Features />
    </section>

    <section id="equipo" class="scroll-mt-24 py-16 border-t border-slate-100">
      <Sectionhead>
        <Fragment slot="title">Conoce al Equipo</Fragment>
        <Fragment slot="desc">
          Cuatro profesionales expertos unidos por la formación AWS re/Start
          para transformar tu negocio.
        </Fragment>
      </Sectionhead>

      <div class="mt-12">
        <Team team={team} columns="4" />
      </div>
    </section>

    <Cta />
  </Container>
</Layout>
