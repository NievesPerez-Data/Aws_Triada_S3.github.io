---
import Layout from "../layouts/Layout.astro";
import Container from "../components/container.astro";
import Sectionhead from "../components/sectionhead.astro";
import PricingCard from "../components/pricing.astro";

const pricing = [
  {
    name: "Business Audit",
    price: "Custom",
    popular: false,
    features: [
      "Auditoría de datos inicial",
      "Mapa de procesos operativos",
      "Detección de cuellos de botella",
      "Identificación de puntos de fuga de ROI",
      "Reporte de recomendaciones",
      "Presentación de hallazgos",
    ],
    button: {
      text: "Solicitar Auditoría",
      link: "/Aws_Triada_S3.github.io/contact",
    },
  },
  {
    name: "Digital Growth",
    price: "Custom",
    popular: true,
    features: [
      "Todo lo de Business Audit",
      "Rediseño UX/UI de embudos",
      "Implementación analítica avanzada",
      "Estrategia de retención",
      "Optimización de conversiones",
      "Soporte estratégico continuo",
    ],
    button: {
      text: "Hablar con Estrategia",
      link: "/Aws_Triada_S3.github.io/contact",
    },
  },
  {
    name: "Cloud Architecture",
    price: "Custom",
    popular: false,
    features: [
      "Todo lo de Digital Growth",
      "Migración a entorno AWS",
      "Automatización Python/SQL",
      "Seguridad y escalabilidad",
      "Mantenimiento técnico",
      "Eficiencia de costes Cloud",
    ],
    button: {
      text: "Consultar Cloud Lead",
      link: "/Aws_Triada_S3.github.io/contact",
    },
  },
];
---

<Layout title="Servicios | TRIAD">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Nuestras Soluciones</Fragment>
      <Fragment slot="desc">
        Estrategias a medida diseñadas para escalar tu negocio mediante datos y tecnología Cloud.
      </Fragment>
    </Sectionhead>

    <div
      class="grid md:grid-cols-3 gap-10 mx-auto max-w-screen-lg mt-12">
      {pricing.map((item) => <PricingCard plan={item} />)}
    </div>
    
    <div class="mt-20 text-center max-w-2xl mx-auto mb-20">
      <p class="text-slate-500 italic text-sm">
        * En <strong>TRIAD</strong> cada proyecto es único. Estos planes sirven como base para entender nuestras áreas de impacto.
      </p>
    </div>
  </Container>
</Layout>